{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex Usage Dock",
  "version": "0.2.0",
  "identifier": "com.nossen.codexusagedock",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Codex Usage Dock",
        "width": 304,
        "height": 326,
        "minWidth": 58,
        "minHeight": 58,
        "maxWidth": 304,
        "maxHeight": 326,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "visible": false,
        "skipTaskbar": true,
        "alwaysOnTop": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "shortDescription": "See Codex usage without leaving your task.",
    "longDescription": "A compact floating dock that follows Codex and shows the five-hour and seven-day usage windows.",
    "category": "Productivity",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
